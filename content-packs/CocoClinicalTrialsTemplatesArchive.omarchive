ough the circulatory system. Blood pressure is expressed in terms of the systolic pressure over diastolic pressure in the cardiac cycle. It is measured in millimetres of mercury above the surrounding atmospheric pressure, or in kilopascals. The difference between the systolic and diastolic pressures is known as pulse pressure, while the average pressure during a cardiac cycle is known as mean arterial pressure."},"abbreviation":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"PatientBloodPressure"}}},"status":"ACTIVE"},{"class":"EntityDetail","headerVersion":1,"type":{"class":"InstanceType","headerVersion":1,"typeDefCategory":"ENTITY_DEF","typeDefGUID":"0db3e6ec-f5ef-4d75-ae38-b7ee6fd6ec0a","typeDefName":"GlossaryTerm","typeDefVersion":1},"instanceProvenanceType":"CONTENT_PACK","metadataCollectionId":"74a786b2-d6d7-401d-b8c1-7d798f752c55","metadataCollectionName":"Coco Pharmaceuticals Clinical Trials Templates","createdBy":"Egeria Project","updatedBy":"Egeria Project","maintainedBy":["Egeria Project"],"createTime":1639984840038,"updateTime":1639984840038,"version":1777388071096,"guid":"c0850381-0cf6-4ebe-9225-6ba666218761","classifications":[{"class":"Classification","headerVersion":1,"type":{"class":"InstanceType","headerVersion":1,"typeDefCategory":"CLASSIFICATION_DEF","typeDefGUID":"93b293c3-1185-4921-aa1c-237d3f0a5d5c","typeDefName":"TemplateSubstitute","typeDefVersion":1},"instanceProvenanceType":"CONTENT_PACK","metadataCollectionId":"74a786b2-d6d7-401d-b8c1-7d798f752c55","metadataCollectionName":"Coco Pharmaceuticals Clinical Trials Templates","createdBy":"Egeria Project","updatedBy":"Egeria Project","maintainedBy":["Egeria Project"],"createTime":1639984840038,"updateTime":1639984840038,"version":1777388071096,"classificationOrigin":"ASSIGNED","name":"TemplateSubstitute","status":"AC