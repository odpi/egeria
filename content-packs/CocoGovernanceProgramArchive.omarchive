sion":1782888272572,"classificationOrigin":"ASSIGNED","name":"Anchors","properties":{"class":"InstanceProperties","headerVersion":1,"instanceProperties":{"anchorTypeName":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"LicenseType"},"anchorDomainName":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"AuthoredReferenceable"}}},"status":"ACTIVE"}],"properties":{"class":"InstanceProperties","headerVersion":1,"instanceProperties":{"summary":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"The license granted by the participant in a clinical trial on the use of their data."},"identifier":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"CT_STANDARD_LICENSE"},"domainIdentifier":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"7fc49104-fd3a-46c8-b6bf-f16b6074cd35","typeName":"int","primitiveDefCategory":"OM_PRIMITIVE_TYPE_INT","primitiveValue":0},"qualifiedName":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"License::CT_STANDARD_LICENSE::Standard Clinical Trial License"},"displayName":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"Standard Clinical Trial License"},"scope":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"This license is part of the agreement made between participant of a clinical trial and Coco Pharmaceuticals.  It describes the types of processing and governance that are permitted/required concerning the use of the data collected during a clinical trial."},"usage":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"This license requires that all data transmitted over a public network is either de-identified or encrypted.  The data can be used for assessing the efficacy of the treatment under test as well as ongoing research into similar conditions/treatments.  It may not be used for any other purposes that jeopardizes the anonymity of the participants since the identity of participants in a clinical trial is confidential.  It may not be transmitted to any third parties without the explicit permission of the affected participant. The participants understand that for legal compliance reasons, Coco Pharmaceuticals will need to retain the data for 20 years."},"description":{"class":"PrimitivePropertyValue","headerVersion":1,"instancePropertyCategory":"PRIMITIVE","typeGUID":"b34a64b9-554a-42b1-8f8a-7d5c2339f9c4","typeName":"string","primitiveDefCategory":"OM_PRIMITIVE_TYPE_STRING","primitiveValue":"Within organization"},"authors":{"class":"ArrayPropertyValue","headerVersion":1,"instancePropertyCategory":"ARRAY","typeGUID":"0428b5d3-f824-459c-b7f5-f8151de597