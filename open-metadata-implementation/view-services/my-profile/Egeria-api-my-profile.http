###
# @name logMyActivity
# Add the supplied notification to the user's activity log.
#
# @param serverName name of the server instances for this request
# @param requestBody details of the user profile to add
#
# @return profile response object or
# InvalidParameterException the userId is null or invalid or
# PropertyServerException a problem retrieving information from the property server(s) or
# UserNotAuthorizedException the requesting user is not authorized to issue this request.
#/
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/my-profile/log-my-activity
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "class" : "NewAttachmentRequestBody",
  "properties" : {
     "class" : "NotificationProperties",
     "qualifiedName" : "Add name here",
     "displayName" : "Add name here",
     "situation" : "Describe notification (title/summary)",
     "description" : "Add text for notification",
     "expectedBehaviour" : "Optionally, if action is to be taken, describe it here"
  }
}


###
