###
# @name getMyAssignedActions
# Return the list of actions that have been assigned to the user's profile, roles, or user identity.
#
# @param serverName name of the server instances for this request
# @param includeUserIds get actions for linked userIds; default=true
# @param includeRoles   get actions for linked roles; default=true
# @param requestBody optional properties to restrict search by and control how the results are formatted
#
# @return profile response object or
# InvalidParameterException the userId is null or invalid or
# PropertyServerException a problem retrieving information from the property server(s) or
# UserNotAuthorizedException the requesting user is not authorized to issue this request.
#
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/my-profile/assigned-actions
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "class" : "ActivityStatusRequestBody",
  "activityStatusList": ["REQUESTED", "WAITING", "IN_PROGRESS"],
  "asOfTime" : "{{$isoTimestamp}}",
  "effectiveTime" : "{{$isoTimestamp}}",
  "forLineage" : false,
  "forDuplicateProcessing" : false
}


