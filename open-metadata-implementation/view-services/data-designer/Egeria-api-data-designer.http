#################################
# Assembling a data specification
# https://egeria-project.org/concepts/data-specification
###

@dataDefinitionGUID=add guid here
@glossaryTermGUID=add guid here
@certificationTypeGUID=add guid here

###
# @name linkDataValueSpecificationDefinition
# Connect an element that is part of a data design to a data class to show that the data class should be used as the specification for the data values when interpreting the data definition.
# Request body is optional.
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/data-designer/data-definitions/{{dataDefinitionGUID}}/data-value-specification-definition/{{dataValueSpecificationGUID}}/attach
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "class" : "NewRelationshipRequestBody",
  "properties": {
      "class" : "DataValueDefinitionProperties",
      "label" : "",
      "description" : ""
  },
  "externalSourceGUID": "add guid here",
  "externalSourceName": "add qualified name here",
  "effectiveTime" : "{{$isoTimestamp}}",
  "forLineage" : false,
  "forDuplicateProcessing" : false
}


###

# @name detachDataValueSpecificationDefinition
# Detach a data definition from a data class.
# Request body is optional.
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/data-designer/data-definitions/{{dataDefinitionGUID}}/data-value-specification-definition/{{dataValueSpecificationGUID}}/detach
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "class" : "DeleteRelationshipRequestBody",
  "externalSourceGUID": "add guid here",
  "externalSourceName": "add qualified name here",
  "effectiveTime" : "{{$isoTimestamp}}",
  "forLineage" : false,
  "forDuplicateProcessing" : false
}


