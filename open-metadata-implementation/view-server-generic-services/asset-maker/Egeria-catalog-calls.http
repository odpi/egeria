###

@softwareCapabilityGUID=4a99a249-8ec4-43a5-9157-4bff67619962

###
# @name getSoftwareCapabilityByGUID
# Retrieve a specific software capability.
# Further Information: https://egeria-project.org/concepts/software-capability
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/asset-maker/software-capabilities/{{softwareCapabilityGUID}}
Authorization: Bearer {{garyToken}}
Content-Type: application/json

{
  "class" : "GetRequestBody"
}


