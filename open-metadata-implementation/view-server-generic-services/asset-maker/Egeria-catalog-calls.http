# Egeria-metadata-collections
# A metadata collection is an asset that describes a logical collection of metadata.

@baseURL=https://localhost:7443
@viewServer=view-server

###
# =====================================================================================================================
# Manage the authentication token.  Run this request to create/refresh the token.

# @name Token (RequestBody)
POST {{baseURL}}/api/token
Content-Type: application/json

{
  "userId" : "peterprofile",
  "password" : "secret"
}

> {% client.global.set("peterToken", response.body); %}


###
# @name Token (RequestBody)
POST {{baseURL}}/api/token
Content-Type: application/json

{
  "userId" : "garygeeke",
  "password" : "secret"
}

> {% client.global.set("garyToken", response.body); %}

###
# @name Token (RequestBody)
POST {{baseURL}}/api/token
Content-Type: application/json

{
  "userId" : "ivorpadlock",
  "password" : "secret"
}

> {% client.global.set("ivorToken", response.body); %}


###
# =====================================================================================================================
# Work with Infrastructure assets


###
# @name find InfrastructureAsset (left-hand navigation - unfiltered - NOT WORKING)
# Returns the list of all infrastructure assets
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/asset-maker/infrastructure-assets/by-search-string
Authorization: Bearer {{ivorToken}}
Content-Type: application/json

{
  "class" : "DeploymentStatusSearchString",
  "graphQueryDepth" : 0
}

###
# @name find InfrastructureAsset (left-hand navigation - unfiltered - WORKAROUND)
# Retrieve the list of asset metadata elements that contain the search string.
#
# Request body provides string to find in the properties
#
# Returns list of matching metadata elements or
#  InvalidParameterException  one of the parameters is invalid
#  UserNotAuthorizedException the user is not authorized to issue this request
#  PropertyServerException    a problem reported in the open metadata server(s)
#
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/asset-maker/assets/by-search-string
Authorization: Bearer {{garyToken}}
Content-Type: application/json

{
  "class" : "SearchStringRequestBody",
  "metadataElementTypeName": "ITInfrastructure",
  "graphQueryDepth": 0
}

###
# @name find InfrastructureAsset (left-hand navigation - unfiltered)
# Returns the list of all infrastructure assets
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/asset-maker/infrastructure-assets/by-search-string
Authorization: Bearer {{garyToken}}
Content-Type: application/json

{
  "class" : "DeploymentStatusSearchString",
  "graphQueryDepth" : 0
}

###
# @name find InfrastructureAsset (left-hand navigation - filtered)
# Returns the list of infrastructure assets matching the search string and optional deployment status.
POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/asset-maker/infrastructure-assets/by-search-string
Authorization: Bearer {{garyToken}}
Content-Type: application/json

{
  "class" : "DeploymentStatusSearchString",
  "deploymentStatusList" : ["ACTIVE", null],
  "searchString" : "ams",
  "graphQueryDepth" : 0
}

###

@infraGUID=75acfa5a-1c6e-4ee6-a358-092921ce9513

###
# @name get InfrastructureAsset for right-hand detail panel
# Return the properties of a specific asset with one level of relationship.

POST {{baseURL}}/servers/{{viewServer}}/api/open-metadata/asset-maker/assets/{{infraGUID}}/retrieve
Authorization: Bearer {{garyToken}}
Content-Type: application/json

{
  "class" : "GetRequestBody",
  "graphQueryDepth" : 1
}

